# === Build Stage ===
FROM node:20-alpine AS builder

# Add libc6-compat for native Node modules (common requirement for tools like esbuild/Vite)
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copy dependency files first to maximize layer caching
COPY package.json package-lock.json* ./

# Install dependencies using `ci` for faster, strictly reproducible builds
RUN npm ci --prefer-offline --no-audit

# Copy the rest of the source code
COPY . .

# Build the application
# NOTE: If your app relies on build-time environment variables, define them here:
# ARG VITE_API_URL
# ENV VITE_API_URL=$VITE_API_URL
RUN npm run build


# === Runtime Stage ===
# Using the official unprivileged Nginx image for out-of-the-box non-root security
FROM nginxinc/nginx-unprivileged:alpine AS runtime

# Set working directory to Nginx asset directory
WORKDIR /usr/share/nginx/html

# Clear default Nginx placeholder files
RUN rm -rf ./*

# Copy the compiled static assets from the builder stage
# IMPORTANT: Change '/app/dist' to '/app/build' if you are using Create React App instead of Vite
COPY --from=builder /app/dist .

# Temporarily switch to root to write the custom Nginx configuration
USER root

# Create a custom Nginx config for Single Page Applications (SPA)
# This ensures React Router handles routing (fixing the 404 error on page refresh)
# and applies aggressive caching to static assets for better performance.
RUN echo $'server {\n\
    listen 8080;\n\
    server_name _;\n\
    root /usr/share/nginx/html;\n\
    index index.html;\n\
    \n\
    # SPA Routing: Fallback to index.html\n\
    location / {\n\
        try_files $uri $uri/ /index.html;\n\
    }\n\
    \n\
    # Cache static assets (CSS, JS, Images, Fonts)\n\
    location ~* \.(?:ico|css|js|gif|jpe?g|png|woff2?|eot|ttf|svg)$ {\n\
        expires 6M;\n\
        access_log off;\n\
        add_header Cache-Control "public";\n\
    }\n\
}' > /etc/nginx/conf.d/default.conf

# Switch back to the safe, unprivileged Nginx user
USER nginx

# Expose the non-privileged port Nginx is configured to listen on
EXPOSE 8080

# Health check using wget (built into Alpine)
HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
    CMD wget -q -O - http://localhost:8080/ || exit 1

# Start Nginx in the foreground
CMD ["nginx", "-g", "daemon off;"]
